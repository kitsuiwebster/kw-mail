# Proton Bridge IMAP Configuration
IMAP_HOST=127.0.0.1
IMAP_PORT=1143
IMAP_USER=your-proton-email@proton.me
IMAP_PASSWORD=your-bridge-password
IMAP_SECURITY=type
IMAP_TLS_VERIFY=false

# Mistral API
MISTRAL_API_KEY=your-mistral-api-key

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
