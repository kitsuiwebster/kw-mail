# Proton Bridge IMAP Configuration
IMAP_HOST=127.0.0.1
IMAP_PORT=1143
IMAP_USER=your-proton-email@proton.me
IMAP_PASSWORD=your-bridge-password
IMAP_SECURITY=STARTTLS
IMAP_TLS_VERIFY=false

# Mistral API
MISTRAL_API_KEY=your-mistral-api-key
MISTRAL_HTTP_TIMEOUT=60
MISTRAL_FORCE_IPV4=true

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
TELEGRAM_FORCE_IPV4=true
TELEGRAM_HTTP_TIMEOUT=5

# Scheduled summaries (daily)
SUMMARY_ENABLED=true
SUMMARY_CRON_TIMES=09:00,21:00
SUMMARY_TZ=Europe/Paris
SUMMARY_HOURS=12

